<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".first_menu"
    android:background="@color/material_dynamic_tertiary90">

    <!-- TODO: Update blank fragment layout -->
    <Button
        android:id="@+id/player_button"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Player vs AI"
        tools:layout_editor_absoluteX="105dp"
        tools:layout_editor_absoluteY="322dp"
        android:layout_gravity="top"
        android:layout_marginTop="150dp"
        android:layout_marginLeft="100dp"/>

    <Button
        android:id="@+id/ai_ai_but"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="AI vs AI"
        tools:layout_editor_absoluteX="105dp"
        android:layout_gravity="center"
        />

    <Button
        android:id="@+id/player_player_but"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:onClick="open_field"
        android:text="Player vs Player"
        tools:layout_editor_absoluteX="105dp"
        android:layout_marginBottom="150dp"
        android:layout_marginLeft="100dp"/>

</FrameLayout>